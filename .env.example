# KBParse optional provider configuration
# Keep real credentials out of git. Copy this file to .env locally and fill values there.

# OpenAI-compatible VLM provider for image/table enrichment.
# Works with OpenAI and any endpoint that supports /v1/chat/completions with image_url input.
KBPARSE_VLM_API_KEY=
KBPARSE_VLM_BASE_URL=https://api.openai.com/v1
KBPARSE_VLM_MODEL=gpt-4o-mini

# Backward-compatible aliases also supported by the code:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_VISION_MODEL=gpt-4o-mini

# Local OpenAI-compatible VLM endpoint example:
# KBPARSE_VLM_BASE_URL=http://localhost:8000/v1
# KBPARSE_VLM_MODEL=local-vision-model
